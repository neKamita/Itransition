@model List<Itransition.Models.Positions.Position>

@{
    ViewData["Title"] = "Home Page";
}

<div class="p-4 mb-4 bg-light rounded-3 border">
    <div class="container-fluid py-2">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-layers-half text-primary me-2"></i>CV Management Platform
        </h1>
        <p class="col-md-10 fs-5 text-muted">
            Explore available positions, create tailored professional profiles, and generate CVs.
        </p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-briefcase me-2"></i>Available Positions</h3>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-secondary">
        No public positions available at the moment.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Company</th>
                    <th>Level</th>
                    <th>Max Projects in CV</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var position in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Positions" asp-action="Details" asp-route-id="@position.Id" class="fw-bold text-primary text-decoration-none">
                                <i class="bi bi-file-text me-1"></i>@position.Title
                            </a>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@position.Company</span>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@position.Level</span>
                        </td>
                        <td>
                            @position.MaxProjectInCv
                        </td>
                        <td>
                            <a asp-controller="Cvs" asp-action="Create" class="btn btn-sm btn-outline-primary">
                                Apply / Create CV <i class="bi bi-arrow-right-short ms-1"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
