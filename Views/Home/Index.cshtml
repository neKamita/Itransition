@model Itransition.ViewModel.HomeDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<header class="mb-4">
    <h1 class="h2 mb-1">Talent dashboard</h1>
    <p class="text-muted mb-0">Current positions, CV activity, and the technologies candidates are working with.</p>
</header>

<section class="row g-3 mb-5" aria-label="Platform statistics">
    <div class="col-6 col-lg">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-briefcase stat-card__icon text-primary" aria-hidden="true"></i>
                <div class="stat-card__value">@Model.VisiblePositionsCount</div>
                <div class="text-muted">Accessible positions</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-people stat-card__icon text-success" aria-hidden="true"></i>
                <div class="stat-card__value">@Model.CandidatesCount</div>
                <div class="text-muted">Candidates</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-person-workspace stat-card__icon text-info" aria-hidden="true"></i>
                <div class="stat-card__value">@Model.RecruitersCount</div>
                <div class="text-muted">Recruiters</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-file-earmark-person stat-card__icon text-warning" aria-hidden="true"></i>
                <div class="stat-card__value">@Model.SubmittedCvsCount</div>
                <div class="text-muted">Submitted CVs</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-clock-history stat-card__icon text-danger" aria-hidden="true"></i>
                <div class="stat-card__value">@Model.CvsCreatedLast24Hours</div>
                <div class="text-muted">CVs in 24 hours</div>
            </div>
        </div>
    </div>
</section>

<div class="row g-4">
    <section class="col-xl-7" aria-labelledby="latestPositionsHeading">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h2 id="latestPositionsHeading" class="h5 mb-0">Latest positions</h2>
                <a asp-controller="Positions" asp-action="Index" class="small text-decoration-none">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th scope="col">Position</th>
                        <th scope="col">Level</th>
                        <th scope="col">CVs</th>
                        <th scope="col">Updated</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.LatestPositions.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">No accessible positions yet.</td></tr>
                    }
                    @foreach (var item in Model.LatestPositions)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Positions" asp-action="Details" asp-route-id="@item.Position.Id" class="fw-semibold text-decoration-none">
                                    @item.Position.Title
                                </a>
                                <div class="small text-muted">@item.Position.Company</div>
                            </td>
                            <td><span class="badge bg-info text-dark">@item.Position.Level</span></td>
                            <td>@item.CvCount</td>
                            <td class="text-muted"><time datetime="@item.Position.UpdatedDate.ToString("O")">@item.Position.UpdatedDate.ToString("g")</time></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="col-xl-5" aria-labelledby="popularPositionsHeading">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h2 id="popularPositionsHeading" class="h5 mb-0">Most popular positions</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th scope="col">Position</th>
                        <th scope="col" class="text-end">Submitted CVs</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.PopularPositions.Count == 0)
                    {
                        <tr><td colspan="2" class="text-center text-muted py-4">No position activity yet.</td></tr>
                    }
                    @foreach (var item in Model.PopularPositions)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Positions" asp-action="Details" asp-route-id="@item.Position.Id" class="fw-semibold text-decoration-none">
                                    @item.Position.Title
                                </a>
                                <div class="small text-muted">@item.Position.Company</div>
                            </td>
                            <td class="text-end"><span class="badge bg-primary rounded-pill">@item.CvCount</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

<section class="card border-0 shadow-sm mt-4" aria-labelledby="popularTagsHeading">
    <div class="card-body p-4">
        <h2 id="popularTagsHeading" class="h5 mb-3">Popular technologies</h2>
        @if (Model.PopularTags.Count == 0)
        {
            <p class="text-muted mb-0">No technology tags are available yet.</p>
        }
        else
        {
            var maxCount = Model.PopularTags.Values.Max();
            <div class="d-flex flex-wrap gap-2 tag-cloud">
                @foreach (var tag in Model.PopularTags)
                {
                    var emphasis = 1 + (0.35 * tag.Value / maxCount);
                    <a asp-controller="Home"
                       asp-action="Search"
                       asp-route-query="@tag.Key"
                       class="badge rounded-pill text-bg-light border text-decoration-none"
                       style="font-size: @(emphasis.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))rem">
                        @tag.Key <span class="visually-hidden">used by</span><span aria-hidden="true"> · </span>@tag.Value
                    </a>
                }
            </div>
        }
    </div>
</section>
