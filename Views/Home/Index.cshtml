@model List<Itransition.Models.Positions.Position>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="fs-1 me-3"><i class="bi bi-briefcase"></i></div>
                <div>
                    <h5 class="card-title mb-0">Positions</h5>
                    <div class="fs-4 fw-bold">@ViewBag.PositionsCount</div>
                </div>
            </div>
            <a asp-controller="Positions" asp-action="Index" class="card-footer text-white text-decoration-none d-flex justify-content-between align-items-center">
                <span class="small">View all positions</span>
                <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="fs-1 me-3"><i class="bi bi-people"></i></div>
                <div>
                    <h5 class="card-title mb-0">Candidates</h5>
                    <div class="fs-4 fw-bold">@ViewBag.CandidatesCount</div>
                </div>
            </div>
            <a asp-controller="CandidateProfiles" asp-action="Index" class="card-footer text-white text-decoration-none d-flex justify-content-between align-items-center">
                <span class="small">View profiles</span>
                <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="fs-1 me-3"><i class="bi bi-file-earmark-text"></i></div>
                <div>
                    <h5 class="card-title mb-0 text-white">Generated CVs</h5>
                    <div class="fs-4 fw-bold text-white">@ViewBag.CvsCount</div>
                </div>
            </div>
            <a asp-controller="Cvs" asp-action="Index" class="card-footer text-white text-decoration-none d-flex justify-content-between align-items-center">
                <span class="small">View CVs</span>
                <i class="bi bi-arrow-right-circle"></i>
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0"><i class="bi bi-stars text-warning me-2"></i>Latest Public Positions</h5>
            </div>
            <div class="card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-secondary">No public positions available.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var position in Model)
                        {
                            <a asp-controller="Positions" asp-action="Details" asp-route-id="@position.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start border-0 border-bottom py-3">
                                <div class="ms-2 me-auto">
                                    <div class="fw-bold text-primary fs-5">@position.Title</div>
                                    <div class="text-muted small mb-1">@position.Company &bull; @position.Level</div>
                                    @if (!string.IsNullOrEmpty(position.Tags))
                                    {
                                        <div>
                                            @foreach (var tag in position.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="badge bg-light text-dark border me-1">@tag.Trim()</span>
                                            }
                                        </div>
                                    }
                                </div>
                                <span class="badge bg-light text-muted border rounded-pill">
                                    @position.CreatedDate.ToString("MMM dd")
                                </span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 h-100 bg-light">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="bi bi-tags text-primary me-2"></i>Trending Technologies</h5>
                @if (ViewBag.PopularTags != null)
                {
                    var tags = ViewBag.PopularTags as Dictionary<string, int>;
                    if (tags != null && tags.Any())
                    {
                        var maxCount = tags.Values.Max();
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var kvp in tags)
                            {
                                // Calculate scale for tag cloud (1.0 to 1.8)
                                double scale = 1.0 + (0.8 * (double)kvp.Value / maxCount);
                                <span class="badge bg-secondary" style="font-size: @(scale)em; padding: 0.4em 0.6em;">
                                    @kvp.Key
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No tags data available yet.</p>
                    }
                }
            </div>
        </div>
    </div>
</div>
