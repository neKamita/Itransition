@model IEnumerable<Itransition.Models.Positions.Position>

@{
    ViewData["Title"] = "Search Results";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-search me-2"></i>Search Results</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary d-flex align-items-center">
        <i class="bi bi-info-circle me-2 fs-5"></i>
        <span>No positions or records found matching your search query.</span>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Company</th>
                    <th>Level</th>
                    <th>Updated</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Positions" asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-primary text-decoration-none">
                                <i class="bi bi-file-text me-1"></i>@item.Title
                            </a>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@item.Company</span>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@item.Level</span>
                        </td>
                        <td class="text-muted small">
                            @item.UpdatedDate.ToString("g")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
