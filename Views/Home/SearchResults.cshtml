@model IEnumerable<Itransition.Models.Positions.Position>

@{
    ViewData["Title"] = "Search Results";
}

<h1>Search Results</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No positions or records found matching your search query.
    </div>
}
else
{
    <table class="table table-striped align-middle mt-3">
        <thead>
            <tr>
                <th>Title</th>
                <th>Company</th>
                <th>Level</th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <a asp-controller="Positions" asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">
                            @item.Title
                        </a>
                    </td>
                    <td>@item.Company</td>
                    <td>@item.Level</td>
                    <td>@item.UpdatedDate</td>
                </tr>
            }
        </tbody>
    </table>
}
