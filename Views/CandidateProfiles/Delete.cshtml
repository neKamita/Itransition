@model Itransition.Models.Profiles.CandidateProfile

@{
    ViewData["Title"] = "Delete Profile";
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-danger text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Delete Profile</h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                    <span>Are you sure you want to permanently delete this candidate profile?</span>
                </div>

                <div class="text-center mb-4">
                    @if (!string.IsNullOrEmpty(Model.PersonalPhotoUrl))
                    {
                        <img src="@Model.PersonalPhotoUrl" alt="Photo" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 100px; height: 100px; font-size: 2.5rem;">
                            <i class="bi bi-person"></i>
                        </div>
                    }
                </div>

                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted" style="width: 35%;"><i class="bi bi-person me-1"></i>First Name</th>
                            <td class="fw-bold">@Html.DisplayFor(model => model.FirstName)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-person me-1"></i>Last Name</th>
                            <td class="fw-bold">@Html.DisplayFor(model => model.LastName)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-geo-alt me-1"></i>Location</th>
                            <td>@(string.IsNullOrEmpty(Model.Location) ? "Not specified" : Model.Location)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-envelope me-1"></i>User</th>
                            <td><span class="badge bg-light text-dark border">@Html.DisplayFor(model => model.User.Id)</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light py-3 d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancel
                </a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Confirm Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
