@model Itransition.Models.Profiles.CandidateProfile
@inject Itransition.Services.IMarkdownRenderer MarkdownRenderer
@using Itransition.Models.Attributes
@using Microsoft.Extensions.Options
@inject IOptions<Itransition.Services.CloudUploadOptions> CloudUpload

@{
    ViewData["Title"] = "Candidate Profile Details";
    var customAttributes = Model!.AttributeValues
        .Where(value => value.AttributeDefinition is { IsBuiltIn: false })
        .OrderBy(value => value.AttributeDefinition.Category?.Name ?? "Uncategorized")
        .ThenBy(value => value.AttributeDefinition.Name)
        .ToList();
}

<div class="d-none" aria-hidden="true">
    @Html.AntiForgeryToken()
</div>

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Candidate Profile</h4>
    </div>

    <div class="card-body p-0">
        <!-- Tabs Nav -->
        <ul class="nav nav-tabs nav-fill bg-light border-bottom-0 pt-2 px-2" id="profileTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="me-tab" data-bs-toggle="tab" data-bs-target="#me-pane" type="button" role="tab" aria-controls="me-pane" aria-selected="true">
                    <i class="bi bi-person me-1"></i>Me
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-pane" type="button" role="tab" aria-controls="info-pane" aria-selected="false">
                    <i class="bi bi-info-circle me-1"></i>Info
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="projects-tab" data-bs-toggle="tab" data-bs-target="#projects-pane" type="button" role="tab" aria-controls="projects-pane" aria-selected="false">
                    <i class="bi bi-kanban me-1"></i>Projects
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="cvs-tab" data-bs-toggle="tab" data-bs-target="#cvs-pane" type="button" role="tab" aria-controls="cvs-pane" aria-selected="false">
                    <i class="bi bi-file-earmark-text me-1"></i>CVs
                </button>
            </li>
        </ul>

        <div class="tab-content p-4" id="profileTabsContent">

            <div class="tab-pane fade show active" id="me-pane" role="tabpanel" aria-labelledby="me-tab" tabindex="0">
                <div class="row align-items-center mb-4">
                    <div class="col-md-3 text-center mb-3 mb-md-0">
                        @if (!string.IsNullOrEmpty(Model.PersonalPhotoUrl))
                        {
                            <img src="@Model.PersonalPhotoUrl" alt="Photo" class="img-fluid rounded-circle shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 150px; height: 150px; font-size: 3.5rem;">
                                <i class="bi bi-person"></i>
                            </div>
                        }
                    </div>
                    <div class="col-md-9">
                        <h3 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h3>
                        <p class="text-muted mb-3"><i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrEmpty(Model.Location) ? "Location not specified" : Model.Location)</p>
                        <div class="p-3 bg-light rounded-3 border mb-3">
                            <p class="mb-0 text-secondary"><strong>Account Email:</strong> @(Model.User?.Email ?? "N/A")</p>
                        </div>
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Edit Basic Info
                        </a>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="info-pane" role="tabpanel" aria-labelledby="info-tab" tabindex="0">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h5 class="fw-bold mb-0">My Attributes</h5>
                    <div class="d-flex flex-wrap gap-2 action-bar">
                        <button id="saveSelectedAttributes" type="button" class="btn btn-sm btn-outline-primary" disabled>
                            <i class="bi bi-check2-all me-1" aria-hidden="true"></i>Save selected
                        </button>
                        <button id="removeSelectedAttributes" type="button" class="btn btn-sm btn-outline-danger" disabled>
                            <i class="bi bi-trash me-1" aria-hidden="true"></i>Remove selected
                        </button>
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addAttributeModal">
                            <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>Add Attribute
                        </button>
                    </div>
                </div>
                <div id="attributeBatchNotice" class="alert d-none" role="status" aria-live="polite"></div>

                @if (!customAttributes.Any())
                {
                    <div class="alert alert-secondary text-center py-4">
                        <i class="bi bi-info-circle display-6 d-block mb-2 text-muted"></i>
                        <p class="mb-0">No attributes added yet. Click "Add Attribute" to enrich your profile.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive border rounded-3">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="text-center" style="width: 3rem;">
                                        <input id="selectAllAttributes" class="form-check-input" type="checkbox" aria-label="Select all profile attributes" />
                                    </th>
                                    <th>Category</th>
                                    <th>Name</th>
                                    <th>Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var attr in customAttributes)
                                {
                                    var definition = attr.AttributeDefinition!;
                                    var inputId = $"val_{attr.Id:N}";
                                    <tr data-attribute-row data-id="@attr.Id" data-version="@attr.Version" data-type="@definition.DataType">
                                        <td class="text-center">
                                            <input class="form-check-input attribute-row-selector" type="checkbox" aria-label="Select @definition.Name" />
                                        </td>
                                        <td><span class="badge bg-secondary">@(definition.Category?.Name ?? "Uncategorized")</span></td>
                                        <td class="fw-semibold">@definition.Name</td>
                                        <td>
                                            @if (attr.AttributeDefinition?.DataType == Itransition.Models.Attributes.AttributeDataType.Dropdown)
                                            {
                                                <select id="@inputId" class="form-select form-select-sm" data-attribute-value>
                                                    <option value="">-- Select --</option>
                                                    @if (attr.AttributeDefinition.Options != null)
                                                    {
                                                        foreach (var opt in attr.AttributeDefinition.Options)
                                                        {
                                                            if (attr.Value == opt.Value)
                                                            {
                                                                <option value="@opt.Value" selected>@opt.Value</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@opt.Value">@opt.Value</option>
                                                            }
                                                        }
                                                    }
                                                </select>
                                            }
                                            else if (attr.AttributeDefinition?.DataType == Itransition.Models.Attributes.AttributeDataType.Boolean)
                                            {
                                                <div class="form-check">
                                                    <input id="@inputId" class="form-check-input" type="checkbox" data-attribute-value @(attr.Value == "true" ? "checked" : "")>
                                                </div>
                                            }
                                            else if (attr.AttributeDefinition?.DataType == AttributeDataType.MarkdownText)
                                            {
                                                <textarea id="@inputId" class="form-control form-control-sm" rows="3" maxlength="10000" data-attribute-value>@attr.Value</textarea>
                                            }
                                            else if (attr.AttributeDefinition?.DataType == AttributeDataType.ImageReference)
                                            {
                                                <input id="@inputId" type="url" class="form-control form-control-sm mb-2" value="@attr.Value" maxlength="2048" placeholder="https://…" data-attribute-value />
                                                <div class="cloud-image-dropzone"
                                                     tabindex="0"
                                                     role="button"
                                                     aria-label="Upload @attr.AttributeDefinition.Name"
                                                     data-cloud-image-upload
                                                     data-target="#@inputId"
                                                     data-cloud-name="@CloudUpload.Value.CloudName"
                                                     data-upload-preset="@CloudUpload.Value.UploadPreset">
                                                    <input type="file" accept="image/*" class="d-none" />
                                                    <img class="rounded d-none" data-upload-preview alt="@attr.AttributeDefinition.Name preview" />
                                                    <div>
                                                        <div class="small fw-semibold">Drop an image or choose a file</div>
                                                        <div class="small text-muted" data-upload-status aria-live="polite">Up to 10 MB.</div>
                                                    </div>
                                                </div>
                                            }
                                            else if (attr.AttributeDefinition?.DataType == AttributeDataType.Numeric)
                                            {
                                                <input id="@inputId" type="number" step="any" class="form-control form-control-sm" value="@attr.Value" data-attribute-value />
                                            }
                                            else if (attr.AttributeDefinition?.DataType == AttributeDataType.Date)
                                            {
                                                <input id="@inputId" type="date" class="form-control form-control-sm" value="@attr.Value" data-attribute-value />
                                            }
                                            else
                                            {
                                                <input id="@inputId" type="text" class="form-control form-control-sm" value="@attr.Value" maxlength="1000" placeholder="Empty" data-attribute-value />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="tab-pane fade" id="projects-pane" role="tabpanel" aria-labelledby="projects-tab" tabindex="0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">My Projects</h5>
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addProjectModal">
                        <i class="bi bi-plus-circle me-1"></i>Add Project
                    </button>
                </div>

                @{
                    var projects = (Model!.Projects ?? [])
                        .OrderByDescending(project => project.EndDate ?? DateTime.MaxValue)
                        .ThenByDescending(project => project.StartDate)
                        .ToList();
                }

                @if (!projects.Any())
                {
                    <div class="alert alert-secondary text-center py-4">
                        <i class="bi bi-kanban display-6 d-block mb-2 text-muted"></i>
                        <p class="mb-0">No projects added yet. Click "Add Project" to showcase your experience.</p>
                    </div>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        @foreach (var proj in projects)
                        {
                            <div class="col">
                                <div class="card h-100 shadow-sm border-0 bg-light">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between">
                                            <h5 class="card-title fw-bold text-primary">@proj.Name</h5>
                                            <div>
                                                <button class="btn btn-sm btn-outline-primary border-0 me-1" onclick="openEditProjectModal('@proj.Id', '@proj.Version', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(proj.Name))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(proj.Description ?? ""))', '@(proj.StartDate?.ToString("yyyy-MM-dd"))', '@(proj.EndDate?.ToString("yyyy-MM-dd"))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(string.Join(", ", (proj.TechnologyTags ?? []).Select(tag => tag.TagName))))')" aria-label="Edit project @proj.Name">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger border-0" onclick="removeProject('@proj.Id', '@proj.Version')" aria-label="Delete project @proj.Name">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <h6 class="card-subtitle mb-2 text-muted small">
                                            <i class="bi bi-calendar3 me-1"></i>
                                            @(proj.StartDate?.ToString("MMM yyyy") ?? "N/A") - @(proj.EndDate?.ToString("MMM yyyy") ?? "Present")
                                        </h6>
                                        <div class="card-text small mt-2 markdown-content">@Html.Raw(MarkdownRenderer.Render((string?)proj.Description))</div>
                                        <div class="mt-2">
                                            @if (proj.TechnologyTags != null)
                                            {
                                                foreach (var tag in proj.TechnologyTags)
                                                {
                                                    <span class="badge bg-secondary me-1">@tag.TagName</span>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tab-pane fade" id="cvs-pane" role="tabpanel" aria-labelledby="cvs-tab" tabindex="0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Generated CVs</h5>
                    <a asp-controller="Positions" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-search me-1"></i>Browse Positions
                    </a>
                </div>

                @{
                    var cvs = Model.Cvs.OrderByDescending(cv => cv.UpdatedDate).ToList();
                }

                @if (!cvs.Any())
                {
                    <div class="alert alert-secondary text-center py-4">
                        <i class="bi bi-file-earmark-text display-6 d-block mb-2 text-muted"></i>
                        <p class="mb-0">You haven't generated any CVs yet. Browse positions to create one.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive border rounded-3">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Position</th>
                                    <th>Status</th>
                                    <th>Likes</th>
                                    <th>Generated On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cv in cvs)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            <a asp-controller="Cvs" asp-action="Details" asp-route-id="@cv.Id" class="text-decoration-none">@cv.Position?.Title</a>
                                        </td>
                                        <td><span class="badge bg-primary">@cv.Status</span></td>
                                        <td><i class="bi bi-heart-fill text-danger me-1"></i>@cv.LikesCount</td>
                                        <td class="text-muted small">@cv.CreatedDate.ToString("d")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addAttributeModal" tabindex="-1" aria-labelledby="addAttributeModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="addAttributeModalLabel">Add Attribute to Profile</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3 mb-3">
            <div class="col-sm-8">
                <label for="profileAttributeCategory" class="form-label">Category</label>
                <select class="form-select" id="profileAttributeCategory">
                    <option value="">All categories</option>
                </select>
            </div>
            <div class="col-sm-4 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="profileRecentAttributes">
                    <label class="form-check-label" for="profileRecentAttributes">Recently used</label>
                </div>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label" for="newAttributeSelect">Search by prefix</label>
            <select class="form-select"
                    id="newAttributeSelect"
                    data-attribute-lookup
                    data-profile-id="@Model.Id"
                    data-category-selector="#profileAttributeCategory"
                    data-recent-selector="#profileRecentAttributes">
                <option value="">-- Choose from library --</option>
            </select>
            <div class="form-text">Start typing an attribute name, or filter by category and recent use.</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="addAttribute()">Add Attribute</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="addProjectModal" tabindex="-1" aria-labelledby="addProjectModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="addProjectModalLabel">Add Project</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">Project Name</label>
            <input type="text" class="form-control" id="newProjectName" maxlength="200" placeholder="e.g. E-commerce Website">
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Start Date</label>
                <input type="date" class="form-control" id="newProjectStart">
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">End Date</label>
                <input type="date" class="form-control" id="newProjectEnd">
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea class="form-control" rows="3" id="newProjectDesc" maxlength="10000" placeholder="Markdown is supported. Describe your role and the project..."></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Technology Tags</label>
            <input type="text" class="form-control" id="newProjectTags" data-tag-autocomplete placeholder="e.g. C#, .NET, React">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="saveProject()">Save Project</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="editProjectModal" tabindex="-1" aria-labelledby="editProjectModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="editProjectModalLabel">Edit Project</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editProjectId">
        <input type="hidden" id="editProjectVersion">
        <div class="mb-3">
            <label class="form-label fw-semibold">Project Name</label>
            <input type="text" class="form-control" id="editProjectName" maxlength="200" placeholder="e.g. E-commerce Website">
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Start Date</label>
                <input type="date" class="form-control" id="editProjectStart">
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">End Date</label>
                <input type="date" class="form-control" id="editProjectEnd">
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea class="form-control" rows="3" id="editProjectDesc" maxlength="10000" placeholder="Markdown is supported. Describe your role and the project..."></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Technology Tags</label>
            <input type="text" class="form-control" id="editProjectTags" data-tag-autocomplete placeholder="e.g. C#, .NET, React">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="updateProject()">Save Changes</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        const profileId = '@Model.Id';
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        function createSecureFormData() {
            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);
            return formData;
        }

        function addAttribute() {
            const attrId = document.getElementById('newAttributeSelect').value;
            if (!attrId) return alert('Please select an attribute');

            const formData = createSecureFormData();
            formData.append('profileId', profileId);
            formData.append('attributeDefinitionId', attrId);

            fetch('/CandidateProfiles/AddAttribute', {
                method: 'POST',
                body: formData
            }).then(res => res.json()).then(data => {
                if(data.success) location.reload();
                else alert('Error adding attribute');
            });
        }

        const attributeRows = Array.from(document.querySelectorAll('[data-attribute-row]'));
        const selectAllAttributes = document.getElementById('selectAllAttributes');
        const saveSelectedButton = document.getElementById('saveSelectedAttributes');
        const removeSelectedButton = document.getElementById('removeSelectedAttributes');
        const attributeBatchNotice = document.getElementById('attributeBatchNotice');

        function selectedAttributeRows() {
            return attributeRows.filter(row => row.querySelector('.attribute-row-selector')?.checked);
        }

        function updateAttributeToolbar() {
            const selectedRows = selectedAttributeRows();
            const selectedCount = selectedRows.length;
            const uploadInProgress = selectedRows.some(row => row.dataset.uploadBusy === 'true');
            if (saveSelectedButton) saveSelectedButton.disabled = selectedCount === 0 || uploadInProgress;
            if (removeSelectedButton) removeSelectedButton.disabled = selectedCount === 0 || uploadInProgress;
            if (selectAllAttributes) {
                selectAllAttributes.checked = selectedCount > 0 && selectedCount === attributeRows.length;
                selectAllAttributes.indeterminate = selectedCount > 0 && selectedCount < attributeRows.length;
            }
        }

        function showAttributeBatchNotice(message, isError) {
            if (!attributeBatchNotice) return;
            attributeBatchNotice.textContent = message;
            attributeBatchNotice.className = `alert ${isError ? 'alert-danger' : 'alert-success'}`;
            attributeBatchNotice.setAttribute('role', isError ? 'alert' : 'status');
        }

        function getAttributeValue(row) {
            const input = row.querySelector('[data-attribute-value]');
            return row.dataset.type === 'Boolean'
                ? (input.checked ? 'true' : 'false')
                : input.value;
        }

        async function postAttributeBatch(url, body) {
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify(body)
            });
            const payload = await response.json().catch(() => null);
            if (!response.ok) {
                throw new Error(payload?.error || 'The selected attributes could not be updated.');
            }
            return payload;
        }

        selectAllAttributes?.addEventListener('change', () => {
            attributeRows.forEach(row => {
                row.querySelector('.attribute-row-selector').checked = selectAllAttributes.checked;
            });
            updateAttributeToolbar();
        });
        attributeRows.forEach(row => {
            row.querySelector('.attribute-row-selector')?.addEventListener('change', updateAttributeToolbar);
            row.querySelector('[data-attribute-value]')?.addEventListener('change', () => {
                row.querySelector('.attribute-row-selector').checked = true;
                updateAttributeToolbar();
            });
        });
        document.addEventListener('cloud-upload-state', updateAttributeToolbar);

        saveSelectedButton?.addEventListener('click', async () => {
            const rows = selectedAttributeRows();
            saveSelectedButton.disabled = true;
            removeSelectedButton.disabled = true;
            try {
                const payload = await postAttributeBatch('/CandidateProfiles/UpdateSelectedAttributes', {
                    profileId,
                    items: rows.map(row => ({
                        id: row.dataset.id,
                        value: getAttributeValue(row),
                        version: Number(row.dataset.version)
                    }))
                });
                rows.forEach(row => {
                    row.dataset.version = payload.versions[row.dataset.id];
                    row.querySelector('.attribute-row-selector').checked = false;
                });
                showAttributeBatchNotice('Selected attributes were saved.', false);
            } catch (error) {
                showAttributeBatchNotice(error instanceof Error ? error.message : 'Save failed.', true);
            } finally {
                updateAttributeToolbar();
            }
        });

        removeSelectedButton?.addEventListener('click', async () => {
            const rows = selectedAttributeRows();
            if (!confirm(`Remove ${rows.length} selected attribute${rows.length === 1 ? '' : 's'}?`)) return;
            saveSelectedButton.disabled = true;
            removeSelectedButton.disabled = true;
            try {
                await postAttributeBatch('/CandidateProfiles/RemoveSelectedAttributes', {
                    profileId,
                    items: rows.map(row => ({ id: row.dataset.id, version: Number(row.dataset.version) }))
                });
                rows.forEach(row => row.remove());
                showAttributeBatchNotice('Selected attributes were removed.', false);
                window.setTimeout(() => location.reload(), 700);
            } catch (error) {
                showAttributeBatchNotice(error instanceof Error ? error.message : 'Delete failed.', true);
                updateAttributeToolbar();
            }
        });

        function saveProject() {
            const name = document.getElementById('newProjectName').value;
            const desc = document.getElementById('newProjectDesc').value;
            const start = document.getElementById('newProjectStart').value;
            const end = document.getElementById('newProjectEnd').value;
            const tags = document.getElementById('newProjectTags').value;

            if (!name) return alert('Name is required');

            const formData = createSecureFormData();
            formData.append('profileId', profileId);
            formData.append('name', name);
            formData.append('description', desc);
            formData.append('startDate', start);
            formData.append('endDate', end);
            formData.append('tags', tags);

            fetch('/CandidateProfiles/AddProject', {
                method: 'POST',
                body: formData
            }).then(async res => {
                if(!res.ok) {
                    const text = await res.text();
                    alert(text || 'Error saving project');
                } else {
                    location.reload();
                }
            });
        }

        function openEditProjectModal(id, version, name, desc, start, end, tags) {
            document.getElementById('editProjectId').value = id;
            document.getElementById('editProjectVersion').value = version;
            document.getElementById('editProjectName').value = name;
            document.getElementById('editProjectDesc').value = desc;
            document.getElementById('editProjectStart').value = start;
            document.getElementById('editProjectEnd').value = end;
            const tagsInput = document.getElementById('editProjectTags');
            if (tagsInput.tomselect) {
                const values = tags.split(',').map(tag => tag.trim()).filter(Boolean);
                tagsInput.tomselect.clear(true);
                for (const value of values) {
                    tagsInput.tomselect.addOption({ value, text: value });
                }
                tagsInput.tomselect.setValue(values, true);
            } else {
                tagsInput.value = tags;
            }
            new bootstrap.Modal(document.getElementById('editProjectModal')).show();
        }

        function updateProject() {
            const id = document.getElementById('editProjectId').value;
            const version = document.getElementById('editProjectVersion').value;
            const name = document.getElementById('editProjectName').value;
            const desc = document.getElementById('editProjectDesc').value;
            const start = document.getElementById('editProjectStart').value;
            const end = document.getElementById('editProjectEnd').value;
            const tags = document.getElementById('editProjectTags').value;

            if (!name) return alert('Name is required');

            const formData = createSecureFormData();
            formData.append('id', id);
            formData.append('version', version);
            formData.append('name', name);
            formData.append('description', desc);
            formData.append('startDate', start);
            formData.append('endDate', end);
            formData.append('tags', tags);

            fetch('/CandidateProfiles/EditProject', {
                method: 'POST',
                body: formData
            }).then(async res => {
                if(!res.ok) {
                    const text = await res.text();
                    alert(text || 'Error saving project');
                } else {
                    location.reload();
                }
            });
        }

        function removeProject(id, version) {
            if(confirm('Are you sure you want to delete this project?')) {
                const formData = createSecureFormData();
                formData.append('id', id);
                formData.append('version', version);
                fetch('/CandidateProfiles/DeleteProject', {
                    method: 'POST',
                    body: formData
                }).then(res => res.json()).then(data => {
                    if(data.success) location.reload();
                });
            }
        }
    </script>
}
