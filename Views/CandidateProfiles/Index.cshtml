@model IEnumerable<Itransition.Models.Profiles.CandidateProfile>

@{
    ViewData["Title"] = "Candidate Profiles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>Candidate Profiles</h2>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i>Create Profile
    </a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th style="width: 60px;">Photo</th>
                <th>Full Name</th>
                <th>Location</th>
                <th>User Email</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.PersonalPhotoUrl))
                    {
                        <img src="@item.PersonalPhotoUrl" alt="Photo" class="rounded-circle shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-person"></i>
                        </div>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-primary text-decoration-none">
                        @item.FirstName @item.LastName
                    </a>
                </td>
                <td>
                    <span class="text-muted"><i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrEmpty(item.Location) ? "Not specified" : item.Location)</span>
                </td>
                <td>
                    <span class="badge bg-light text-dark border">@(item.User?.Email ?? "N/A")</span>
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-1">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
