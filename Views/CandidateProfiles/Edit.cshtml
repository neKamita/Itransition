@model Itransition.ViewModel.CandidateProfileViewModel
@using Microsoft.Extensions.Options
@inject IOptions<Itransition.Services.CloudUploadOptions> CloudUpload

@{
    ViewData["Title"] = "Edit Candidate Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />
                    <input type="hidden" asp-for="FirstNameVersion" />
                    <input type="hidden" asp-for="LastNameVersion" />
                    <input type="hidden" asp-for="LocationVersion" />
                    <input type="hidden" asp-for="PersonalPhotoVersion" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Location</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Location" class="form-control" />
                        </div>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Profile Photo</label>
                        <input asp-for="PersonalPhotoUrl" id="photoUrlInput" type="url" class="form-control mb-2" maxlength="2048" placeholder="https://…" />
                        <div class="cloud-image-dropzone"
                             tabindex="0"
                             role="button"
                             aria-label="Replace profile photo"
                             data-cloud-image-upload
                             data-target="#photoUrlInput"
                             data-cloud-name="@CloudUpload.Value.CloudName"
                             data-upload-preset="@CloudUpload.Value.UploadPreset">
                            <input type="file" accept="image/*" class="d-none" />
                            <img class="rounded d-none" data-upload-preview alt="Selected profile photo preview" />
                            <div>
                                <div class="fw-semibold"><i class="bi bi-cloud-arrow-up me-1" aria-hidden="true"></i>Drop an image or choose a file</div>
                                <div class="small text-muted" data-upload-status aria-live="polite">JPEG, PNG or WebP, up to 10 MB.</div>
                            </div>
                        </div>
                        <span asp-validation-for="PersonalPhotoUrl" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2" id="submitBtn">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <a asp-action="Index" class="small fw-bold text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
