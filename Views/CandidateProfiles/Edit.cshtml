@model Itransition.ViewModel.CandidateProfileViewModel

@{
    ViewData["Title"] = "Edit Candidate Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="RowVersion" />
                    <input type="hidden" asp-for="PersonalPhotoUrl" id="photoUrlInput" />
                    <input type="file" id="localFileInput" accept="image/*" class="d-none" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Location</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Location" class="form-control" />
                        </div>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Profile Photo</label>
                        <div id="dropzone_box" class="p-4 text-center border border-2 border-secondary rounded-3 bg-light" style="border-style: dashed !important; cursor: pointer;">
                            <div id="dropzone_content" class="@(!string.IsNullOrEmpty(Model.PersonalPhotoUrl) ? "d-none" : "")">
                                <i class="bi bi-cloud-arrow-up text-primary display-4 mb-2 d-block"></i>
                                <h6 class="fw-bold mb-1">Drag & Drop or Click to Upload Photo</h6>
                                <span class="text-muted small">Image will be uploaded to cloud storage</span>
                            </div>
                            <div id="upload_spinner" class="d-none py-3">
                                <div class="spinner-border text-primary mb-2" role="status">
                                    <span class="visually-hidden">Uploading...</span>
                                </div>
                                <div class="text-muted small fw-bold">Uploading to Cloudinary...</div>
                            </div>
                            <div id="preview_container" class="@(!string.IsNullOrEmpty(Model.PersonalPhotoUrl) ? "" : "d-none") mt-2">
                                <img id="photo_preview" src="@Model.PersonalPhotoUrl" alt="Preview" class="img-fluid rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" />
                                <div class="mt-2 text-success small fw-bold">Click zone to replace photo</div>
                            </div>
                        </div>
                        <div id="upload_error" class="text-danger small mt-1 d-none"></div>
                        <span asp-validation-for="PersonalPhotoUrl" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2" id="submitBtn">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <a asp-action="Index" class="small fw-bold text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        const CLOUD_NAME = 'oxlpitjk';
        const UPLOAD_PRESET = 'transition';
        const UPLOAD_URL = 'https://api.cloudinary.com/v1_1/' + CLOUD_NAME + '/image/upload';

        const dropzone = document.getElementById('dropzone_box');
        const localFileInput = document.getElementById('localFileInput');
        const submitBtn = document.getElementById('submitBtn');

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
            document.body.addEventListener(eventName, (e) => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropzone.addEventListener(eventName, () => dropzone.classList.add('border-primary', 'bg-white'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropzone.addEventListener(eventName, () => dropzone.classList.remove('border-primary', 'bg-white'), false);
        });

        dropzone.addEventListener('drop', (e) => {
            let files = e.dataTransfer.files;
            if (files && files.length > 0) {
                uploadToCloudinary(files[0]);
            }
        }, false);

        dropzone.addEventListener('click', () => {
            localFileInput.click();
        }, false);

        localFileInput.addEventListener('change', (e) => {
            if (e.target.files && e.target.files.length > 0) {
                uploadToCloudinary(e.target.files[0]);
            }
        });

        function showSpinner() {
            document.getElementById('dropzone_content').classList.add('d-none');
            document.getElementById('preview_container').classList.add('d-none');
            document.getElementById('upload_spinner').classList.remove('d-none');
            document.getElementById('upload_error').classList.add('d-none');
            submitBtn.disabled = true;
        }

        function showPreview(url) {
            document.getElementById('upload_spinner').classList.add('d-none');
            document.getElementById('dropzone_content').classList.add('d-none');
            document.getElementById('photo_preview').src = url;
            document.getElementById('preview_container').classList.remove('d-none');
            submitBtn.disabled = false;
        }

        function showError(message) {
            document.getElementById('upload_spinner').classList.add('d-none');
            document.getElementById('dropzone_content').classList.remove('d-none');
            document.getElementById('preview_container').classList.add('d-none');
            var errorEl = document.getElementById('upload_error');
            errorEl.textContent = message;
            errorEl.classList.remove('d-none');
            submitBtn.disabled = false;
        }

        function uploadToCloudinary(file) {
            if (!file.type.startsWith('image/')) {
                showError('Please select an image file.');
                return;
            }

            if (file.size > 10 * 1024 * 1024) {
                showError('File size must be under 10 MB.');
                return;
            }

            showSpinner();

            var formData = new FormData();
            formData.append('file', file);
            formData.append('upload_preset', UPLOAD_PRESET);

            fetch(UPLOAD_URL, {
                method: 'POST',
                body: formData
            })
            .then(function(response) {
                if (!response.ok) {
                    return response.json().then(function(err) {
                        throw new Error(err.error ? err.error.message : 'Upload failed');
                    });
                }
                return response.json();
            })
            .then(function(data) {
                document.getElementById('photoUrlInput').value = data.secure_url;
                showPreview(data.secure_url);
            })
            .catch(function(error) {
                showError('Upload failed: ' + error.message);
            });
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
