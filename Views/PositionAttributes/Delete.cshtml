@model Itransition.Models.Positions.PositionAttribute

@{
    ViewData["Title"] = "Delete Requirement";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-danger text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Delete Requirement</h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                    <span>Are you sure you want to permanently delete this requirement?</span>
                </div>

                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted" style="width: 35%;"><i class="bi bi-briefcase me-1"></i>Position</th>
                            <td class="fw-bold">@Model.Position.Title</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-tag me-1"></i>Attribute</th>
                            <td><span class="badge bg-secondary">@Model.AttributeDefinition.Category.Name</span></td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-sort-numeric-down me-1"></i>Order</th>
                            <td>@Html.DisplayFor(model => model.OrderIndex)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light py-3 d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancel
                </a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />
                    <input type="hidden" name="positionVersion" value="@Model.Position.Version" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Confirm Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
