@model IEnumerable<Itransition.Models.Positions.PositionAttribute>

@{
    ViewData["Title"] = "Position Attributes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-sliders me-2"></i>Position Attributes</h2>
</div>

<p class="text-muted">Add or remove requirements from the position page. Use this table to inspect and reorder existing requirements.</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Position Title</th>
                <th>Attribute Category</th>
                <th>Order Index</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">@(item.Position?.Title ?? "N/A")</a>
                </td>
                <td>
                    <span class="badge bg-secondary">@(item.AttributeDefinition?.Category?.Name ?? "N/A")</span>
                </td>
                <td>
                    <span class="badge bg-info text-dark">#@item.OrderIndex</span>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
