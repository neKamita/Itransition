@model Itransition.Models.Positions.PositionAttribute

@{
    ViewData["Title"] = "Edit Requirement";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Requirement</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />
                    <input type="hidden" name="positionVersion" value="@ViewData["PositionVersion"]" />

                    <div class="mb-3">
                        <span class="form-label fw-semibold d-block">Position</span>
                        <div class="form-control bg-light">@Model.Position.Title</div>
                    </div>

                    <div class="mb-3">
                        <span class="form-label fw-semibold d-block">Attribute Definition</span>
                        <div class="form-control bg-light">@Model.AttributeDefinition.Name</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OrderIndex" class="form-label fw-semibold">Order Index</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-sort-numeric-down"></i></span>
                            <input asp-for="OrderIndex" name="orderIndex" class="form-control" min="0" max="1000" />
                        </div>
                        <span asp-validation-for="OrderIndex" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <a asp-action="Index" class="small fw-bold text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
