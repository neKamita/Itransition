@model Itransition.Models.Positions.PositionAttribute

@{
    ViewData["Title"] = "Requirement Details";
}

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-sliders me-2"></i>Requirement Details</h4>
    </div>
    <div class="card-body p-4">
        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <th class="text-muted" style="width: 30%;"><i class="bi bi-briefcase me-1"></i>Position</th>
                    <td class="fw-bold">@Html.DisplayFor(model => model.Position.Id)</td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-tag me-1"></i>Attribute</th>
                    <td><span class="badge bg-secondary">@Html.DisplayFor(model => model.AttributeDefinition.Category)</span></td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-sort-numeric-down me-1"></i>Order Index</th>
                    <td>@Html.DisplayFor(model => model.OrderIndex)</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light py-3 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Edit Requirement
        </a>
    </div>
</div>
