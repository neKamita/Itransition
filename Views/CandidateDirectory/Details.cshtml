@model Itransition.ViewModel.CandidateDirectoryDetailsViewModel

@{
    ViewData["Title"] = $"{Model.CandidateName} - Published CVs";
}

<nav aria-label="Breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Cvs" asp-action="Index">CVs</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.CandidateName</li>
    </ol>
</nav>

<section aria-labelledby="candidateDirectoryHeading" class="card border-0 shadow-sm">
    <div class="card-header bg-dark text-white d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
        <div>
            <h1 id="candidateDirectoryHeading" class="h3 mb-1">@Model.CandidateName</h1>
            <p class="mb-0 text-white-50">Candidate overview for recruitment review</p>
        </div>
        <span class="badge text-bg-info d-inline-flex align-items-center gap-1 px-3 py-2">
            <i class="bi bi-eye" aria-hidden="true"></i>
            Read-only
        </span>
    </div>

    <div class="card-body p-0">
        <div class="alert alert-light border-0 border-bottom rounded-0 mb-0 d-flex gap-2 align-items-start" role="note">
            <i class="bi bi-shield-check text-success fs-5" aria-hidden="true"></i>
            <div>
                Only published CVs that are currently available to this candidate are shown.
                Private profile attributes and editing controls are not available here.
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <caption class="visually-hidden">Published CVs for @Model.CandidateName</caption>
                <thead class="table-light">
                    <tr>
                        <th scope="col">Position</th>
                        <th scope="col">Company</th>
                        <th scope="col">Level</th>
                        <th scope="col">Likes</th>
                        <th scope="col">Updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cv in Model.PublishedCvs)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Cvs" asp-action="Details" asp-route-id="@cv.Id" class="fw-semibold text-decoration-none py-2 d-inline-block">
                                    @cv.PositionTitle
                                </a>
                            </td>
                            <td>@cv.Company</td>
                            <td><span class="badge text-bg-secondary">@cv.Level</span></td>
                            <td><i class="bi bi-heart-fill text-danger me-1" aria-hidden="true"></i>@cv.LikesCount</td>
                            <td><time datetime="@cv.UpdatedDate.ToString("O")">@cv.UpdatedDate.ToString("g")</time></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="mt-3">
    <a asp-controller="Cvs" asp-action="Index" class="btn btn-outline-secondary py-2 px-3">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Back to CVs
    </a>
</div>
