@model IEnumerable<Itransition.Models.Attributes.AttributeOption>

@{
    ViewData["Title"] = "Attribute Options";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-list-check me-2"></i>Attribute Options</h2>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Create New Option
    </a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Option Value</th>
                <th>Attribute Category</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    <span class="fw-bold text-dark">@item.Value</span>
                </td>
                <td>
                    <span class="badge bg-secondary">@(item.AttributeDefinition?.Category ?? "N/A")</span>
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-1">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
