@model Itransition.Models.Attributes.AttributeOption

@{
    ViewData["Title"] = "Edit Option";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Option</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />

                    <div class="mb-3">
                        <label asp-for="Value" class="form-label fw-semibold">Value</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-list-check"></i></span>
                            <input asp-for="Value" class="form-control" />
                        </div>
                        <span asp-validation-for="Value" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AttributeDefinitionId" class="form-label fw-semibold">Attribute Definition</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tag"></i></span>
                            <select asp-for="AttributeDefinitionId" class="form-select" asp-items="ViewBag.AttributeDefinitionId"></select>
                        </div>
                        <span asp-validation-for="AttributeDefinitionId" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-circle me-1"></i>Save Changes
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <a asp-action="Index" class="small fw-bold text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
