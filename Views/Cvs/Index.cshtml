@model IEnumerable<Itransition.Models.Cvs.Cv>

@{
    ViewData["Title"] = "CVs";
    var canManageCvs = User.IsInRole("Candidate") || User.IsInRole("Administrator");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-text me-2"></i>CVs</h2>
</div>

@if (TempData["CvSuccess"] is string successMessage)
{
    <div class="alert alert-success d-flex gap-2 align-items-center" role="status" aria-live="polite">
        <i class="bi bi-check-circle" aria-hidden="true"></i>
        <span>@successMessage</span>
    </div>
}
@if (TempData["CvNotice"] is string noticeMessage)
{
    <div class="alert alert-info d-flex gap-2 align-items-center" role="status" aria-live="polite">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
        <span>@noticeMessage</span>
    </div>
}

<form id="bulkForm" method="post">
    @if (canManageCvs)
    {
    <div class="mb-3 d-flex flex-wrap gap-2 action-bar">
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Create New
        </a>
        <button type="submit" asp-action="DeleteSelected" class="btn btn-danger btn-sm" onclick="return confirm('Delete selected items?')">
            <i class="bi bi-trash me-1"></i>Delete Selected
        </button>
    </div>
    }

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    @if (canManageCvs)
                    {
                        <th style="width: 40px;">
                            <input type="checkbox" id="selectAll" class="form-check-input" aria-label="Select all CVs" />
                        </th>
                    }
                    <th>Candidate Profile</th>
                    <th>Position</th>
                    <th>Status</th>
                    <th>Likes</th>
                    <th>Updated Date</th>
                </tr>
            </thead>
            <tbody>
        @if (!Model.Any())
        {
                <tr>
                    <td colspan="@(canManageCvs ? 6 : 5)" class="text-center text-muted py-5">
                        <i class="bi bi-file-earmark-text fs-2 d-block mb-2" aria-hidden="true"></i>
                        @(User.IsInRole("Recruiter")
                            ? "No published CVs are available for review."
                            : "No CVs have been created yet.")
                    </td>
                </tr>
        }
        @foreach (var item in Model) {
                <tr>
                    @if (canManageCvs)
                    {
                        <td>
                            <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input select-item" aria-label="Select CV for @item.Position?.Title" />
                            <input type="hidden" name="selectedVersions[@item.Id]" value="@item.Version" />
                        </td>
                    }
                    <td>
                        <a asp-controller="@(User.IsInRole("Recruiter") || User.IsInRole("Administrator") ? "CandidateDirectory" : "Cvs")"
                           asp-action="Details"
                           asp-route-id="@(User.IsInRole("Recruiter") || User.IsInRole("Administrator") ? item.CandidateProfileId : item.Id)"
                           class="fw-bold text-primary text-decoration-none py-2 d-inline-block">
                            <i class="bi bi-person-badge me-1"></i>@item.CandidateProfile?.FirstName @item.CandidateProfile?.LastName
                        </a>
                    </td>
                    <td>
                        <span class="badge bg-secondary">@item.Position?.Title</span>
                    </td>
                    <td>
                        <span class="badge bg-primary">@item.Status</span>
                    </td>
                    <td>
                        <span class="fw-bold"><i class="bi bi-heart-fill text-danger me-1"></i>@item.LikesCount</span>
                    </td>
                    <td>
                        @item.UpdatedDate.ToString("g")
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('selectAll')?.addEventListener('change', function() {
            var checkboxes = document.querySelectorAll('.select-item');
            for (var checkbox of checkboxes) {
                checkbox.checked = this.checked;
            }
        });
    </script>
}
