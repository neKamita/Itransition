@model Itransition.Models.Cvs.Cv

@{
    ViewData["Title"] = "Create CV";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-plus me-2"></i>Create CV</h4>
            </div>
            <div class="card-body p-4">
                @if (ViewData["ExistingCvId"] is Guid existingCvId)
                {
                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-start gap-3 p-3 mb-4"
                         role="alert"
                         aria-live="assertive">
                        <span class="cv-notice-icon" aria-hidden="true">
                            <i class="bi bi-file-earmark-check"></i>
                        </span>
                        <div class="flex-grow-1">
                            <h2 class="h6 alert-heading fw-bold mb-1">CV already exists</h2>
                            <p class="mb-3">
                                This candidate already has a CV for the selected position. Open the existing CV or choose another position.
                            </p>
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-action="Details" asp-route-id="@existingCvId" class="btn btn-warning btn-sm">
                                    <i class="bi bi-eye me-1" aria-hidden="true"></i>Open existing CV
                                </a>
                                <a href="#PositionId" class="btn btn-outline-dark btn-sm">
                                    <i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i>Choose another position
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="PositionId" class="form-label fw-semibold">Position</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                            <select asp-for="PositionId" class="form-select" asp-items="ViewBag.PositionId"></select>
                        </div>
                    </div>

                    @if (ViewBag.CandidateProfileId != null)
                    {
                        <div class="mb-3">
                            <label asp-for="CandidateProfileId" class="form-label fw-semibold">Candidate</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <select asp-for="CandidateProfileId" class="form-select" asp-items="ViewBag.CandidateProfileId">
                                    <option value="">-- Select Candidate --</option>
                                </select>
                            </div>
                            <span asp-validation-for="CandidateProfileId" class="text-danger small"></span>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-circle me-1"></i>Create CV
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <a asp-action="Index" class="small fw-bold text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
