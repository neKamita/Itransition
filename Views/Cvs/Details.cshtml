@model Itransition.Models.Cvs.Cv

@{
    ViewData["Title"] = "CV Details";
}

<h1>CV Details</h1>

<div>
    <h4>CV #@Model.Id</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            <span class="badge bg-primary">@Model.Status</span>
        </dd>
        <dt class="col-sm-2">
            Likes
        </dt>
        <dd class="col-sm-10">
            <span class="fw-bold">@Model.LikesCount</span>
            @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
            {
                <form asp-action="Like" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Like (+1)</button>
                </form>
            }
        </dd>
        <dt class="col-sm-2">
            Created Date
        </dt>
        <dd class="col-sm-10">
            @Model.CreatedDate
        </dd>
        <dt class="col-sm-2">
            Updated Date
        </dt>
        <dd class="col-sm-10">
            @Model.UpdatedDate
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
