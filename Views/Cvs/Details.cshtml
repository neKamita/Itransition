@model Itransition.Models.Cvs.Cv

@{
    ViewData["Title"] = "CV Details";
}

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-person me-2"></i>CV Details</h4>
        <span class="badge bg-primary fs-6">@Model.Status</span>
    </div>
    <div class="card-body p-4">
        <div class="row align-items-center mb-4">
            <div class="col-md-3 text-center mb-3 mb-md-0">
                @if (!string.IsNullOrEmpty(Model.CandidateProfile?.PersonalPhotoUrl))
                {
                    <img src="@Model.CandidateProfile.PersonalPhotoUrl" alt="Photo" class="img-fluid rounded-circle shadow-sm" style="width: 140px; height: 140px; object-fit: cover;" />
                }
                else
                {
                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 140px; height: 140px; font-size: 3rem;">
                        <i class="bi bi-person"></i>
                    </div>
                }
            </div>
            <div class="col-md-9">
                <h3 class="fw-bold mb-1">@Model.CandidateProfile?.FirstName @Model.CandidateProfile?.LastName</h3>
                <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i>@(Model.CandidateProfile?.Location ?? "Not specified")</p>
                <div class="p-3 bg-light rounded-3 mb-3">
                    <h5 class="fw-bold text-dark mb-1"><i class="bi bi-briefcase me-2"></i>@Model.Position?.Title</h5>
                    <p class="mb-0 text-secondary">Company: <strong>@Model.Position?.Company</strong> | Level: <span class="badge bg-info text-dark">@Model.Position?.Level</span></p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="fs-5">
                        <i class="bi bi-heart-fill text-danger me-1"></i>
                        <span class="fw-bold">@Model.LikesCount</span> Likes
                    </div>
                    @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
                    {
                        <form asp-action="Like" asp-route-id="@Model.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-hand-thumbs-up me-1"></i>Like (+1)
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <hr class="my-4" />

        <div class="row">
            <div class="col-md-5 mb-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-card-checklist me-2"></i>Required Skills</h5>
                <ul class="list-group shadow-sm">
                    @if (Model.Position?.PositionRequiredAttributes != null && Model.Position.PositionRequiredAttributes.Any())
                    {
                        foreach (var req in Model.Position.PositionRequiredAttributes.OrderBy(r => r.OrderIndex))
                        {
                            var candidateVal = Model.CandidateProfile?.AttributeValues?.FirstOrDefault(av => av.AttributeDefinitionId == req.AttributeDefinitionId);
                            bool isMissing = candidateVal == null || string.IsNullOrWhiteSpace(candidateVal.Value);

                            <li class="list-group-item @(isMissing ? "list-group-item-danger" : "") d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-secondary me-1">@req.AttributeDefinition.Category</span>
                                    <strong>@req.AttributeDefinition.Name</strong>
                                </div>
                                @if (isMissing)
                                {
                                    <span class="badge bg-danger">MISSING</span>
                                }
                                else
                                {
                                    <span>@candidateVal!.Value</span>
                                }
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">No specific attributes required by this position.</li>
                    }
                </ul>
            </div>

            <div class="col-md-7 mb-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-kanban me-2"></i>Relevant Projects</h5>
                @{
                    var positionTags = (Model.Position?.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim().ToLower()).ToList();
                    var allProjects = Model.CandidateProfile?.Projects ?? new List<Itransition.Models.Profiles.ProjectProfile>();

                    var relevantProjects = new List<Itransition.Models.Profiles.ProjectProfile>();

                    if (positionTags.Any())
                    {
                        foreach (var proj in allProjects)
                        {
                            var projTags = proj.TechnologyTags.Select(t => t.TagName.ToLower()).ToList();
                            if (projTags.Intersect(positionTags).Any())
                            {
                                relevantProjects.Add(proj);
                            }
                        }
                    }
                    else
                    {
                    }
                }

                @if (relevantProjects.Any())
                {
                    <div class="row g-3">
                        @foreach (var proj in relevantProjects)
                        {
                            <div class="col-12">
                                <div class="card border-primary h-100 shadow-sm">
                                    <div class="card-body">
                                        <h6 class="card-title fw-bold">@proj.Name</h6>
                                        <h6 class="card-subtitle mb-2 text-muted small">@proj.StartDate?.ToString("MMM yyyy") - @(proj.EndDate?.ToString("MMM yyyy") ?? "Present")</h6>
                                        <p class="card-text small mb-2">@proj.Description</p>
                                        <div>
                                            @foreach (var tag in proj.TechnologyTags)
                                            {
                                                bool isMatch = positionTags.Contains(tag.TagName.ToLower());
                                                <span class="badge @(isMatch ? "bg-primary" : "bg-secondary") me-1">@tag.TagName</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary">
                        @if (!positionTags.Any())
                        {
                            <text>This position does not specify any Technology Tags to match against.</text>
                        }
                        else
                        {
                            <text>The candidate has no projects matching the position's required tags (@string.Join(", ", positionTags)).</text>
                        }
                    </div>
                }
            </div>
        </div>

        <hr class="my-4" />

        <div class="row text-muted small">
            <div class="col-6">
                <strong>Created Date:</strong> @Model.CreatedDate.ToString("g")
            </div>
            <div class="col-6 text-end">
                <strong>Updated Date:</strong> @Model.UpdatedDate.ToString("g")
            </div>
        </div>
    </div>
    <div class="card-footer bg-light py-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>
