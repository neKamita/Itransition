@model Itransition.Models.Attributes.AttributeDefinition

@{
    ViewData["Title"] = "Attribute Details";
}

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-tag me-2"></i>Attribute Details</h4>
        <span class="badge bg-info text-dark fs-6">@Model.DataType</span>
    </div>
    <div class="card-body p-4">
        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <th class="text-muted" style="width: 30%;"><i class="bi bi-tag me-1"></i>Name</th>
                    <td class="fw-bold">@Html.DisplayFor(model => model.Name)</td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-folder me-1"></i>Category</th>
                    <td><span class="badge bg-secondary">@Html.DisplayFor(model => model.Category)</span></td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-card-text me-1"></i>Description</th>
                    <td>@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-code-square me-1"></i>Data Type</th>
                    <td><span class="badge bg-info text-dark">@Html.DisplayFor(model => model.DataType)</span></td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light py-3 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Edit Attribute
        </a>
    </div>
</div>
