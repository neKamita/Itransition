@model Itransition.Models.Attributes.AttributeDefinition

@{
    ViewData["Title"] = "Attribute Details";
}

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-tag me-2"></i>Attribute Details</h4>
        <span class="badge bg-info text-dark fs-6">@Model.DataType</span>
    </div>
    <div class="card-body p-4">
        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <th class="text-muted" style="width: 30%;"><i class="bi bi-tag me-1"></i>Name</th>
                    <td class="fw-bold">@Html.DisplayFor(model => model.Name)</td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-folder me-1"></i>Category</th>
                    <td><span class="badge bg-secondary">@Model.Category.Name</span></td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-card-text me-1"></i>Description</th>
                    <td>@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</td>
                </tr>
                <tr>
                    <th class="text-muted"><i class="bi bi-code-square me-1"></i>Data Type</th>
                    <td><span class="badge bg-info text-dark">@Html.DisplayFor(model => model.DataType)</span></td>
                </tr>
            </tbody>
        </table>
    </div>
    
    @if (Model.DataType == Itransition.Models.Attributes.AttributeDataType.Dropdown)
    {
        <div class="card-body p-4 border-top bg-light">
            <h5 class="fw-bold mb-3"><i class="bi bi-list-ul me-2"></i>Dropdown Options</h5>
            
            <div class="row">
                <div class="col-md-6">
                    @if (Model.Options.Any())
                    {
                        <ul class="list-group mb-3">
                            @foreach (var opt in Model.Options)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @opt.Value
                                    <form asp-action="RemoveOption" method="post" class="d-inline">
                                        <input type="hidden" name="optionId" value="@opt.Id" />
                                        <input type="hidden" name="attributeId" value="@Model.Id" />
                                        <input type="hidden" name="version" value="@opt.Version" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this option?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-secondary">No options defined yet.</div>
                    }
                </div>
                <div class="col-md-6">
                    <form asp-action="AddOption" method="post" class="card shadow-sm border-0 p-3">
                        <h6 class="fw-bold mb-2">Add New Option</h6>
                        <input type="hidden" name="attributeId" value="@Model.Id" />
                        <div class="input-group">
                            <input type="text" name="optionValue" class="form-control" placeholder="Option value..." required />
                            <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="card-footer bg-light py-3 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Edit Attribute
        </a>
    </div>
</div>
