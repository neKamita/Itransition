@using Microsoft.AspNetCore.Identity
@using Itransition.Models
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav d-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item text-white-50 small me-2">
            <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
        </li>
        <li class="nav-item">
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">
                <i class="bi bi-box-arrow-in-right me-1"></i>Login
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">
                <i class="bi bi-person-plus me-1"></i>Register
            </a>
        </li>
    }
</ul>
