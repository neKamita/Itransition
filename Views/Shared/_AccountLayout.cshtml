<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Itransition</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="bg-light min-vh-100">
<header>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid gap-3">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Itransition</a>
            <form class="d-flex ms-auto" asp-controller="Home" asp-action="Search" method="get" role="search">
                <label class="visually-hidden" for="accountGlobalSearch">Search positions</label>
                <div class="input-group input-group-sm">
                    <input id="accountGlobalSearch" class="form-control" type="search" name="query" placeholder="Search positions" maxlength="200" required />
                    <button class="btn btn-outline-light" type="submit" aria-label="Search">
                        <i class="bi bi-search" aria-hidden="true"></i>
                    </button>
                </div>
            </form>
        </div>
    </nav>
</header>

<main class="container py-5" role="main">
    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
