@model Itransition.Models.Positions.Position
@using Itransition.Services

@{
    ViewData["Title"] = "Position Details";
    var positionCvs = ViewData["PositionCvs"] as IReadOnlyList<Itransition.Models.Cvs.Cv> ?? [];
}

@if (TempData["PositionSuccess"] is string successMessage)
{
    <div class="alert alert-success" role="status" aria-live="polite">@successMessage</div>
}
@if (TempData["PositionError"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert" aria-live="assertive">@errorMessage</div>
}

<div class="card shadow-sm border-0 rounded-3 my-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-briefcase me-2"></i>@Model.Title</h4>
        <span class="badge @(Model.IsPublic ? "bg-success" : "bg-secondary") fs-6">
            @(Model.IsPublic ? "Public" : "Restricted")
        </span>
    </div>
    <div class="card-body p-4">
        <div class="row mb-3">
            <div class="col-md-6 mb-2">
                <strong><i class="bi bi-building me-1"></i>Company:</strong> @Model.Company
            </div>
            <div class="col-md-6 mb-2">
                <strong><i class="bi bi-bar-chart me-1"></i>Level:</strong> <span class="badge bg-info text-dark">@Model.Level</span>
            </div>
        </div>

        <div class="mb-3 p-3 bg-light rounded-3">
            <h6 class="fw-bold"><i class="bi bi-card-text me-1"></i>Description</h6>
            <p class="mb-2 text-secondary">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>

            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <h6 class="fw-bold mt-3"><i class="bi bi-tags me-1"></i>Technology Tags</h6>
                <div>
                    @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="badge bg-primary me-1">@tag.Trim()</span>
                    }
                </div>
            }
        </div>

        <div class="row mb-3">
            <div class="col-md-6 mb-2">
                <strong><i class="bi bi-list-task me-1"></i>Max Projects in CV:</strong> @Model.MaxProjectInCv
            </div>
            <div class="col-md-6 mb-2">
                <strong><i class="bi bi-clock me-1"></i>Created:</strong> @Model.CreatedDate.ToString("g")
            </div>
        </div>

        @if (User.IsInRole("Administrator") || User.IsInRole("Recruiter"))
        {
            <hr class="my-4" />

            <div class="row">
                <div class="col-md-6 mb-4">
                    <h5 class="fw-bold"><i class="bi bi-check2-square me-2"></i>Required Attributes</h5>
                    <p class="text-muted small mb-2">Attributes that candidate MUST have to generate a CV.</p>
                    <ul class="list-group mb-3 shadow-sm">
                        @if (!Model.PositionRequiredAttributes.Any())
                        {
                            <li class="list-group-item text-muted">No requirements set.</li>
                        }
                        @foreach (var req in Model.PositionRequiredAttributes)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-secondary me-1">@req.AttributeDefinition.Category.Name</span>
                                    @req.AttributeDefinition.Name
                                </div>
                                <form asp-action="RemoveRequirement" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@req.Id" />
                                    <input type="hidden" name="positionId" value="@Model.Id" />
                                    <input type="hidden" name="version" value="@req.Version" />
                                    <input type="hidden" name="positionVersion" value="@Model.Version" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Remove requirement @req.AttributeDefinition.Name" onclick="return confirm('Remove requirement?');"><i class="bi bi-trash" aria-hidden="true"></i></button>
                                </form>
                            </li>
                        }
                    </ul>

                    <form asp-action="AddRequirement" method="post" class="card shadow-sm border-0 p-3 bg-light">
                        <input type="hidden" name="positionId" value="@Model.Id" />
                        <input type="hidden" name="positionVersion" value="@Model.Version" />
                        <h6 class="fw-bold mb-2 fs-6">Add Requirement</h6>
                        <div class="row g-2 mb-2">
                            <div class="col-sm-7">
                                <label for="requirementCategory" class="form-label small mb-1">Category</label>
                                <select id="requirementCategory" class="form-select form-select-sm">
                                    <option value="">All categories</option>
                                </select>
                            </div>
                            <div class="col-sm-5 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input id="recentRequirements" class="form-check-input" type="checkbox">
                                    <label for="recentRequirements" class="form-check-label small">Recently used</label>
                                </div>
                            </div>
                        </div>
                        <div class="input-group input-group-sm">
                            <select id="requirementAttribute"
                                    name="attributeId"
                                    class="form-select"
                                    data-attribute-lookup
                                    data-category-selector="#requirementCategory"
                                    data-recent-selector="#recentRequirements"
                                    required>
                                <option value="">-- Select Attribute --</option>
                            </select>
                            <button type="submit" class="btn btn-primary" aria-label="Add selected requirement"><i class="bi bi-plus" aria-hidden="true"></i></button>
                        </div>
                        <div class="form-text">Type a name prefix or filter the shared library.</div>
                    </form>
                </div>

                <div class="col-md-6 mb-4">
                    <h5 class="fw-bold"><i class="bi bi-shield-lock me-2"></i>Access Rules</h5>
                    <p class="text-muted small mb-3">Restricted positions require candidates to match every configured rule.</p>

                    @if (TempData["AccessRuleError"] is string accessRuleError)
                    {
                        <div class="alert alert-danger d-flex gap-2 align-items-start" role="alert" aria-live="assertive">
                            <i class="bi bi-exclamation-circle flex-shrink-0" aria-hidden="true"></i>
                            <span>@accessRuleError</span>
                        </div>
                    }

                    @if (TempData["AccessRuleSuccess"] is string accessRuleSuccess)
                    {
                        <div class="alert alert-success d-flex gap-2 align-items-start" role="status" aria-live="polite">
                            <i class="bi bi-check-circle flex-shrink-0" aria-hidden="true"></i>
                            <span>@accessRuleSuccess</span>
                        </div>
                    }

                    @if (Model.IsPublic)
                    {
                        <div class="alert alert-success border-0 shadow-sm" role="status">
                            <div class="d-flex gap-2 align-items-start">
                                <i class="bi bi-globe2 fs-5 flex-shrink-0" aria-hidden="true"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Filters are not required</h6>
                                    <p class="mb-2">
                                        This position is public, so access rules are not evaluated.
                                        @if (Model.PositionAccessRules.Count > 0)
                                        {
                                            <span>@Model.PositionAccessRules.Count saved rule(s) will become active if the position is changed to Restricted.</span>
                                        }
                                    </p>
                                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-pencil me-1" aria-hidden="true"></i>Change visibility
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <ul class="list-group mb-3 shadow-sm">
                            @if (!Model.PositionAccessRules.Any())
                            {
                                <li class="list-group-item text-muted d-flex gap-2 align-items-center">
                                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                                    No access rules are configured. Candidates cannot access this position yet.
                                </li>
                            }
                            @foreach (var rule in Model.PositionAccessRules)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center gap-2">
                                    <div>
                                        <span class="badge bg-secondary me-1">@rule.AttributeDefinition.Category.Name</span>
                                        @rule.AttributeDefinition.Name
                                        <span class="badge bg-dark mx-1">@rule.Operator</span>
                                        <strong>@rule.TargetValue</strong>
                                    </div>
                                    <form asp-action="RemoveAccessRule" method="post" class="d-inline flex-shrink-0">
                                        <input type="hidden" name="id" value="@rule.Id" />
                                        <input type="hidden" name="positionId" value="@Model.Id" />
                                        <input type="hidden" name="version" value="@rule.Version" />
                                        <input type="hidden" name="positionVersion" value="@Model.Version" />
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                aria-label="Remove access rule for @rule.AttributeDefinition.Name"
                                                title="Remove rule"
                                                onclick="return confirm('Remove rule?');">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>

                        <form asp-action="AddAccessRule" method="post" class="card shadow-sm border-0 p-3 bg-light">
                            <input type="hidden" name="positionId" value="@Model.Id" />
                            <input type="hidden" name="positionVersion" value="@Model.Version" />
                            <h6 class="fw-bold mb-3 fs-6">Add Access Rule</h6>

                            <div class="row g-2 mb-3">
                                <div class="col-sm-7">
                                    <label for="accessRuleCategory" class="form-label small mb-1">Category</label>
                                    <select id="accessRuleCategory" class="form-select form-select-sm">
                                        <option value="">All categories</option>
                                    </select>
                                </div>
                                <div class="col-sm-5 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <input id="recentAccessRuleAttributes" class="form-check-input" type="checkbox">
                                        <label for="recentAccessRuleAttributes" class="form-check-label small">Recently used</label>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="accessRuleAttribute" class="form-label fw-semibold">Candidate attribute</label>
                                <select id="accessRuleAttribute"
                                        name="attributeId"
                                        class="form-select form-select-sm"
                                        aria-describedby="accessRuleHelp"
                                        data-attribute-lookup
                                        data-category-selector="#accessRuleCategory"
                                        data-recent-selector="#recentAccessRuleAttributes"
                                        required>
                                    <option value="">Select an attribute</option>
                                </select>
                                <div id="accessRuleHelp" class="form-text">Search by prefix or filter the library. Operators depend on the selected data type.</div>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-sm-5">
                                    <label for="accessRuleOperator" class="form-label fw-semibold">Operator</label>
                                    <select id="accessRuleOperator" name="operatorType" class="form-select form-select-sm" required disabled>
                                        <option value="">Select an attribute first</option>
                                    </select>
                                </div>
                                <div class="col-sm-7">
                                    <label id="accessRuleTargetLabel" for="accessRuleTargetInput" class="form-label fw-semibold">Target value</label>
                                    <input id="accessRuleTargetInput"
                                           name="targetValue"
                                           type="text"
                                           class="form-control form-control-sm"
                                           autocomplete="off"
                                           required
                                           disabled />
                                    <select id="accessRuleTargetSelect"
                                            class="form-select form-select-sm d-none"
                                            required
                                            disabled></select>
                                </div>
                            </div>

                            <button id="addAccessRuleButton" type="submit" class="btn btn-primary btn-sm align-self-start" disabled>
                                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Add rule
                            </button>
                        </form>
                    }
                </div>
            </div>

            <hr class="my-4" />
            <section aria-labelledby="positionCvsHeading">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                    <div>
                        <h2 id="positionCvsHeading" class="h5 fw-bold mb-1">
                            <i class="bi bi-file-earmark-person me-2" aria-hidden="true"></i>CVs for this position
                        </h2>
                        <p class="text-muted small mb-0">
                            @(User.IsInRole("Administrator")
                                ? "Administrators can inspect every CV, including drafts."
                                : "Only published CVs from candidates who still have access are shown.")
                        </p>
                    </div>
                    <span class="badge bg-secondary">@positionCvs.Count</span>
                </div>

                <div class="table-responsive border rounded">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Candidate</th>
                                <th scope="col">Status</th>
                                <th scope="col">Likes</th>
                                <th scope="col">Updated</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (positionCvs.Count == 0)
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">No CVs are available for review.</td></tr>
                            }
                            @foreach (var cv in positionCvs)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="CandidateDirectory" asp-action="Details" asp-route-id="@cv.CandidateProfileId" class="fw-semibold text-decoration-none py-2 d-inline-block">
                                            @cv.CandidateProfile.FirstName @cv.CandidateProfile.LastName
                                        </a>
                                    </td>
                                    <td><span class="badge @(cv.Status == Itransition.Models.Cvs.CvStatuses.Published ? "bg-success" : "bg-secondary")">@cv.Status</span></td>
                                    <td><i class="bi bi-heart-fill text-danger me-1" aria-hidden="true"></i>@cv.LikesCount</td>
                                    <td>@cv.UpdatedDate.ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
    <div class="card-footer bg-light py-3 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        <div class="d-flex flex-wrap gap-2 action-bar">
            @if (User.IsInRole("Recruiter") || User.IsInRole("Administrator"))
            {
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i>Edit Position
                </a>
                <form asp-action="Duplicate" asp-route-id="@Model!.Id" method="post">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-copy me-1" aria-hidden="true"></i>Duplicate
                    </button>
                </form>
            }
            @if (User.IsInRole("Administrator"))
            {
                <a asp-controller="Cvs" asp-action="Create" asp-route-positionId="@Model?.Id" class="btn btn-primary">
                    <i class="bi bi-file-earmark-plus me-1"></i>Create CV (Select Candidate)
                </a>
            }
            else if (User.IsInRole("Candidate"))
            {
                <form asp-controller="Cvs" asp-action="Create" method="post" class="d-inline">
                    <input type="hidden" name="PositionId" value="@Model?.Id" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-file-earmark-plus me-1"></i>Apply / Create CV
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const attributeSelect = document.getElementById('accessRuleAttribute');
            const operatorSelect = document.getElementById('accessRuleOperator');
            const targetInput = document.getElementById('accessRuleTargetInput');
            const targetSelect = document.getElementById('accessRuleTargetSelect');
            const targetLabel = document.getElementById('accessRuleTargetLabel');
            const submitButton = document.getElementById('addAccessRuleButton');

            if (!attributeSelect || !operatorSelect || !targetInput || !targetSelect || !targetLabel || !submitButton) {
                return;
            }

            const operatorLabels = {
                '==': 'Equals (==)',
                '!=': 'Does not equal (!=)',
                '>': 'Greater than (>)',
                '<': 'Less than (<)',
                'CONTAINS': 'Contains'
            };

            function addChoice(select, value, text) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = text;
                select.appendChild(option);
            }

            function useTextTarget(dataType) {
                targetSelect.classList.add('d-none');
                targetSelect.disabled = true;
                targetSelect.removeAttribute('name');
                targetSelect.replaceChildren();

                targetInput.classList.remove('d-none');
                targetInput.disabled = false;
                targetInput.name = 'targetValue';
                targetInput.value = '';
                targetInput.type = dataType === 'Numeric' ? 'number' : dataType === 'Date' ? 'date' : 'text';

                if (dataType === 'Numeric') {
                    targetInput.step = 'any';
                    targetInput.placeholder = 'For example, 7.5';
                } else {
                    targetInput.removeAttribute('step');
                    targetInput.placeholder = dataType === 'Period' ? 'Enter a period value' : 'Enter a value';
                }

                targetLabel.htmlFor = targetInput.id;
            }

            function useChoiceTarget(dataType, selectedAttribute) {
                targetInput.classList.add('d-none');
                targetInput.disabled = true;
                targetInput.removeAttribute('name');

                targetSelect.classList.remove('d-none');
                targetSelect.disabled = false;
                targetSelect.name = 'targetValue';
                targetSelect.replaceChildren();
                addChoice(targetSelect, '', 'Select a value');

                if (dataType === 'Boolean') {
                    addChoice(targetSelect, 'true', 'True');
                    addChoice(targetSelect, 'false', 'False');
                } else {
                    const configuredOptions = Array.isArray(selectedAttribute.options)
                        ? selectedAttribute.options
                        : (() => {
                            try { return JSON.parse(selectedAttribute.dataset?.options || '[]'); }
                            catch { return []; }
                        })();

                    for (const value of configuredOptions) {
                        addChoice(targetSelect, value, value);
                    }
                }

                targetLabel.htmlFor = targetSelect.id;
            }

            function updateRuleEditor() {
                const selectedValue = attributeSelect.value;
                const selectedAttribute = attributeSelect.tomselect?.options?.[selectedValue]
                    || attributeSelect.selectedOptions[0];
                const dataType = selectedAttribute?.dataType || selectedAttribute?.dataset?.type;
                const operatorData = selectedAttribute?.operators || selectedAttribute?.dataset?.operators || [];
                const operators = Array.isArray(operatorData)
                    ? operatorData
                    : operatorData.split('|').filter(Boolean);

                operatorSelect.replaceChildren();
                addChoice(operatorSelect, '', operators.length ? 'Select an operator' : 'Select an attribute first');

                for (const operator of operators) {
                    addChoice(operatorSelect, operator, operatorLabels[operator] || operator);
                }

                const hasAttribute = Boolean(dataType && operators.length);
                operatorSelect.disabled = !hasAttribute;
                submitButton.disabled = !hasAttribute;

                if (!hasAttribute) {
                    targetInput.value = '';
                    targetInput.disabled = true;
                    targetSelect.disabled = true;
                    return;
                }

                if (dataType === 'Boolean' || dataType === 'Dropdown') {
                    useChoiceTarget(dataType, selectedAttribute);
                } else {
                    useTextTarget(dataType);
                }
            }

            attributeSelect.addEventListener('change', updateRuleEditor);
            updateRuleEditor();
        })();
    </script>
}
