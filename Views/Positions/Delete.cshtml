@model Itransition.Models.Positions.Position

@{
    ViewData["Title"] = "Delete Position";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-3 my-4">
            <div class="card-header bg-danger text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Delete Position</h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                    <span>Are you sure you want to permanently delete this position?</span>
                </div>

                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted" style="width: 35%;"><i class="bi bi-briefcase me-1"></i>Title</th>
                            <td class="fw-bold">@Html.DisplayFor(model => model.Title)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-card-text me-1"></i>Description</th>
                            <td>@Html.DisplayFor(model => model.Description)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-building me-1"></i>Company</th>
                            <td><span class="badge bg-secondary">@Html.DisplayFor(model => model.Company)</span></td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-bar-chart me-1"></i>Level</th>
                            <td><span class="badge bg-info text-dark">@Html.DisplayFor(model => model.Level)</span></td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-list-task me-1"></i>Max Projects</th>
                            <td>@Html.DisplayFor(model => model.MaxProjectInCv)</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-eye me-1"></i>Public</th>
                            <td>
                                @if (Model.IsPublic)
                                {
                                    <span class="badge bg-success">Public</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Private</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light py-3 d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancel
                </a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Confirm Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
